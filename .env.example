# Copy to .env for local dev. Also set these in your hosting provider
# (Vercel/Netlify → Project → Environment Variables) for the deployed app.
# Leave unset to run purely local (localStorage only, Cloud Sync page shows setup steps).
#
# Setting these turns on the shared team workspace: signing into SceneTrackable
# transparently signs into the cloud, and every user shares one production.
# Run supabase/schema.sql first, and turn OFF Authentication → Providers →
# Email → "Confirm email" — see README "Go live".

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
